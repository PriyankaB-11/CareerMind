generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ApplicationStatus {
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
}

enum CompanyType {
  STARTUP
  MID_SIZE
  ENTERPRISE
  UNKNOWN
}

enum InterviewStage {
  RESUME
  ONLINE_ASSESSMENT
  TECHNICAL
  HR
  UNKNOWN
}

enum AdviceOutcome {
  PENDING
  SUCCESS
  FAILURE
}

enum InsightType {
  SEMANTIC
  REFLECTIVE
  WEEKLY
  AUTOPSY
}

enum EventType {
  RESUME_UPLOAD
  JOB_MATCH
  REJECTION
  APPLICATION
  ADVICE_OUTCOME
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  resumes       Resume[]
  skills        Skill[]
  projects      Project[]
  applications  Application[]
  rejections    Rejection[]
  adviceLogs    AdviceLog[]
  insights      Insight[]
  events        CareerEvent[]
  targetCompanies TargetCompany[]
  interviewPreps InterviewPrep[]
}

model TargetCompany {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String
  name       String
  role       String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviewPreps InterviewPrep[]

  @@index([userId, createdAt])
  @@index([userId, name])
}

model InterviewPrep {
  id              String   @id @default(cuid())
  userId          String
  targetCompanyId String?  @db.Uuid
  company         String
  role            String?
  userSkills      String[]
  technical       String[]
  behavioral      String[]
  coding          String[]
  focusAreas      String[]
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCompany   TargetCompany? @relation(fields: [targetCompanyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([targetCompanyId])
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  filename   String
  text       String
  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, uploadedAt])
}

model Skill {
  id         String   @id @default(cuid())
  userId     String
  name       String
  source     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Application {
  id          String            @id @default(cuid())
  userId      String
  company     String
  role        String
  source      String?
  status      ApplicationStatus @default(APPLIED)
  appliedAt   DateTime          @default(now())
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  rejections  Rejection[]

  @@index([userId, appliedAt])
  @@index([userId, status])
}

model Rejection {
  id            String         @id @default(cuid())
  userId        String
  applicationId String?
  company       String
  role          String
  companyType   CompanyType    @default(UNKNOWN)
  stage         InterviewStage @default(UNKNOWN)
  reasonText    String?
  missingSkills String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  application   Application?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, companyType])
}

model AdviceLog {
  id            String        @id @default(cuid())
  userId        String
  strategy      String
  advice        String
  outcome       AdviceOutcome @default(PENDING)
  priorityScore Float         @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, strategy])
  @@index([userId, outcome])
}

model Insight {
  id        String      @id @default(cuid())
  userId    String
  type      InsightType
  title     String
  content   Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, updatedAt])
}

model CareerEvent {
  id        String    @id @default(cuid())
  userId    String
  type      EventType
  title     String
  metadata  Json?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
